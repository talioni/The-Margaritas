# Copy to .env to override. docker-compose reads .env automatically.

# Set to true on the Raspberry Pi to enable real GPIO. This makes the
# hadrware-ctrl container privileged (host device access) AND tells the app to
# drive the real stepper/servo. Leave false / unset on dev machines — the
# controller starts anywhere and runs in dry-run mode (logs only, no GPIO).
GPIO_ENABLED=false
